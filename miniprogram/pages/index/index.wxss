.container {
  padding: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  border-bottom: 1px solid #eee;
}

.pos {
  width: 10%;
  font-weight: bold;
}

.medal {
  display: inline-block;
  margin-right: 6rpx;
  transform: translateY(1rpx);
}

.name {
  width: 30%;
}

.nationality {
  width: 20%;
}

.team {
  width: 20%;
  color: gray;
}

.points {
  width: 20%;
  text-align: right;
}